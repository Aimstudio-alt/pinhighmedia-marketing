---
import Layout from '../layouts/Layout.astro'
import FlagshipCard from '../components/FlagshipCard.astro'
import ToolCard from '../components/ToolCard.astro'

const title = 'Products — Pin High Media'
const description =
  'Two flagship SaaS products and a suite of focused tools for UK golf clubs and county unions — CountyConsent, ClubSentinel, and specialist tools built for the realities of club operations.'

const iconClass = 'h-5 w-5'
const iconProps = `stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" fill="none"`

const tools = [
  {
    name: 'County Golf Courtesy System',
    description:
      'Automates inter-club courtesy arrangements at county level. Configure rules, manage approvals, and give members a clear view of where they can play.',
    icon: `<svg class="${iconClass}" viewBox="0 0 24 24" ${iconProps}><path d="M3 12h18"/><path d="M12 3v18"/><circle cx="12" cy="12" r="9"/></svg>`,
  },
  {
    name: 'Golf Genius Connector',
    description:
      "A bridge between Golf Genius and your club's specific workflows. Closes the gaps between Golf Genius events and your club's admin, billing, and communications.",
    icon: `<svg class="${iconClass}" viewBox="0 0 24 24" ${iconProps}><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>`,
  },
  {
    name: 'Golf League Tracker',
    description:
      'Automated league management and results tracking for club leagues, inter-club competitions, and county events. Live leaderboards, automatic scoring, and zero spreadsheet chaos.',
    icon: `<svg class="${iconClass}" viewBox="0 0 24 24" ${iconProps}><path d="M8 21h8"/><path d="M12 17v4"/><path d="M7 4h10v5a5 5 0 0 1-10 0V4Z"/><path d="M17 4h4v3a3 3 0 0 1-3 3"/><path d="M7 4H3v3a3 3 0 0 0 3 3"/></svg>`,
  },
  {
    name: 'Bar & Kitchen Booking',
    description:
      'Integrated F&B booking built for club venues. Members book tables, events, and functions directly — your staff see the full picture in one place.',
    icon: `<svg class="${iconClass}" viewBox="0 0 24 24" ${iconProps}><path d="M3 7h18"/><path d="M5 7v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7"/><path d="M8 7V5a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/><path d="M9 12h6"/></svg>`,
  },
  {
    name: 'Online Newsletter System',
    description:
      'Member communications built into the club ecosystem. Send targeted newsletters, event updates, and club news without needing a separate platform.',
    icon: `<svg class="${iconClass}" viewBox="0 0 24 24" ${iconProps}><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg>`,
  },
  {
    name: 'County Golf Marketing Survey',
    description:
      'Data collection and insight tools for county golf bodies. Run surveys, track participation, and get the data you need to make informed decisions about county-wide programmes.',
    icon: `<svg class="${iconClass}" viewBox="0 0 24 24" ${iconProps}><path d="M3 3v18h18"/><path d="M7 14l4-4 4 4 5-5"/></svg>`,
  },
  {
    name: 'Fully Integrated Club Websites',
    description:
      'Modern, connected club websites built around how clubs actually operate. Member areas, booking integrations, news, and fixtures — all in one place, all working together.',
    icon: `<svg class="${iconClass}" viewBox="0 0 24 24" ${iconProps}><circle cx="12" cy="12" r="9"/><path d="M3 12h18"/><path d="M12 3a14 14 0 0 1 0 18"/><path d="M12 3a14 14 0 0 0 0 18"/></svg>`,
  },
  {
    name: 'Drone Videography',
    description:
      'Professional course flyovers and promotional content for clubs and county competitions. Bring your course to life for marketing, social, and member engagement.',
    icon: `<svg class="${iconClass}" viewBox="0 0 24 24" ${iconProps}><circle cx="6" cy="6" r="3"/><circle cx="18" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="18" r="3"/><path d="M9 6h6"/><path d="M6 9v6"/><path d="M18 9v6"/><path d="M9 18h6"/><rect x="10" y="10" width="4" height="4" rx="1"/></svg>`,
  },
]
---

<Layout title={title} description={description}>
  <!-- Hero -->
  <section>
    <div class="mx-auto max-w-4xl px-6 pt-16 pb-10 sm:px-8 md:pt-24 md:pb-14">
      <span class="text-[12px] font-semibold uppercase tracking-[0.18em] text-forest-500">
        What we build
      </span>
      <h1 class="mt-4 text-4xl font-bold tracking-tight text-forest-900 sm:text-5xl md:text-[56px] md:leading-[1.08]">
        What we build.
      </h1>
      <p class="mt-6 max-w-2xl text-[17px] leading-relaxed text-ink-muted sm:text-lg">
        Purpose-built software for UK golf clubs and county unions, organised into two flagship SaaS products and a suite of focused tools for specific operational needs.
      </p>
    </div>
  </section>

  <!-- Flagship -->
  <section class="border-t border-forest-100/80 bg-cream-deep/30">
    <div class="mx-auto max-w-6xl px-6 py-20 sm:px-8 md:py-24">
      <div class="max-w-2xl">
        <span class="text-[12px] font-semibold uppercase tracking-[0.18em] text-forest-500">
          Flagship products
        </span>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-forest-900 sm:text-4xl">
          Flagship Products
        </h2>
      </div>

      <div class="mt-12 grid gap-8 md:grid-cols-2">
        <FlagshipCard
          name="CountyConsent"
          tagline="Junior golf parental consent and safeguarding, properly digital."
          description="Replace paper forms, WhatsApp chains, and shared spreadsheets with one secure, GDPR-compliant system for clubs, counties, and tour organisers."
          href="https://countyconsent.co.uk"
          accent="forest"
          image="/preview-countyconsent.png"
          imageAlt="CountyConsent product preview"
        />
        <FlagshipCard
          name="ClubSentinel"
          tagline="Health & safety compliance and asset management for golf clubs, powered by AI."
          description="RIDDOR-ready incident reporting, training records, document management, and a live compliance score — designed to keep your club audit-ready, automatically."
          href="https://clubsentinel.co.uk"
          accent="brass"
          image="/preview-clubsentinel.png"
          imageAlt="ClubSentinel product preview"
        />
      </div>
    </div>
  </section>

  <!-- Specialist tools -->
  <section>
    <div class="mx-auto max-w-6xl px-6 py-20 sm:px-8 md:py-24">
      <div class="max-w-2xl">
        <span class="text-[12px] font-semibold uppercase tracking-[0.18em] text-forest-500">
          Specialist tools
        </span>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-forest-900 sm:text-4xl">
          Specialist Tools
        </h2>
        <p class="mt-4 text-[16px] leading-relaxed text-ink-muted">
          Alongside our flagship SaaS products, we build focused tools that solve specific operational challenges for clubs and county unions. If one of these sounds like something you need, get in touch.
        </p>
      </div>

      <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {tools.map((tool) => <ToolCard name={tool.name} description={tool.description} icon={tool.icon} />)}
      </div>

      <div class="mt-14 border-t border-forest-100 pt-10 text-center">
        <a
          href="/contact"
          class="group inline-flex items-center gap-1.5 text-[15px] font-semibold text-forest-700 transition-colors hover:text-forest-900"
        >
          If one of these sounds like something you need, get in touch
          <span aria-hidden="true" class="transition-transform duration-200 group-hover:translate-x-0.5">→</span>
        </a>
      </div>
    </div>
  </section>
</Layout>
