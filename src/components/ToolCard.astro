---
interface Props {
  name: string
  description: string
  icon: string
}

const { name, description, icon } = Astro.props
---

<div class="flex h-full flex-col rounded-xl border border-forest-100 bg-white p-6 transition-all duration-200 hover:border-forest-200 hover:bg-forest-50/40">
  <div class="grid h-10 w-10 place-items-center rounded-lg bg-forest-100 text-forest-700">
    <Fragment set:html={icon} />
  </div>
  <h3 class="mt-5 text-[16px] font-semibold tracking-tight text-forest-900">
    {name}
  </h3>
  <p class="mt-2 text-[14px] leading-relaxed text-ink-muted">
    {description}
  </p>
</div>
