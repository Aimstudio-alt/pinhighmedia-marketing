---
interface Props {
  name: string
  tagline: string
  description: string
  href: string
  accent?: 'forest' | 'brass'
  image?: string
  imageAlt?: string
}

const {
  name,
  tagline,
  description,
  href,
  accent = 'forest',
  image,
  imageAlt,
} = Astro.props
const accentClass = accent === 'brass' ? 'text-brass' : 'text-forest-700'
const displayHref = href.replace(/^https?:\/\//, '').replace(/\/$/, '')
---

<article class="group flex h-full flex-col overflow-hidden rounded-2xl border border-forest-100 bg-white transition-all duration-200 hover:border-forest-200 hover:shadow-[0_12px_40px_-12px_rgba(14,31,16,0.35)]">
  {image && (
    <div class="border-b border-forest-100 bg-cream-deep/50 p-5 sm:p-6">
      <img
        src={image}
        alt={imageAlt ?? `${name} product preview`}
        width="1200"
        height="630"
        loading="lazy"
        decoding="async"
        class="block w-full rounded-lg ring-1 ring-forest-900/10 shadow-[0_8px_20px_-8px_rgba(14,31,16,0.25)]"
      />
    </div>
  )}

  <div class="flex flex-1 flex-col p-8 sm:p-10">
    <div class={`flex items-center gap-2.5 ${accentClass}`}>
      <span class="inline-block h-2 w-2 rounded-full bg-current" aria-hidden="true"></span>
      <span class="text-[11px] font-semibold uppercase tracking-[0.18em]">Flagship SaaS</span>
    </div>
    <h3 class="mt-5 text-3xl font-bold tracking-tight text-forest-900 sm:text-[32px]">
      {name}
    </h3>
    <p class="mt-3 text-lg font-medium leading-snug text-forest-700">
      {tagline}
    </p>
    <p class="mt-5 text-[15px] leading-relaxed text-ink-muted">
      {description}
    </p>

    <div class="mt-auto pt-8">
      <a
        href={href}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1.5 text-[15px] font-semibold text-forest-700 transition-colors hover:text-forest-900"
      >
        Visit {displayHref}
        <span aria-hidden="true" class="transition-transform duration-200 group-hover:translate-x-0.5">→</span>
      </a>
    </div>
  </div>
</article>
