---
const { pathname } = Astro.url
const isActive = (href: string) =>
  href === '/' ? pathname === '/' : pathname.startsWith(href)

const links = [
  { href: '/products', label: 'Products' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
]
---

<header class="border-b border-forest-100/60 bg-cream/80 backdrop-blur supports-[backdrop-filter]:bg-cream/60">
  <nav class="mx-auto flex max-w-6xl items-center justify-between gap-6 px-6 py-5 sm:px-8 md:py-6">
    <a href="/" class="group flex items-center gap-2.5">
      <span aria-hidden="true" class="grid h-8 w-8 place-items-center rounded-md bg-forest-700 text-cream transition-colors group-hover:bg-forest-900">
        <span class="text-sm font-bold tracking-tight">P</span>
      </span>
      <span class="text-[15px] font-semibold tracking-tight text-forest-900">
        Pin High Media
      </span>
    </a>

    <ul class="flex items-center gap-1 text-[14px] font-medium sm:gap-2">
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              class:list={[
                'rounded-md px-3 py-2 transition-colors',
                isActive(link.href)
                  ? 'bg-forest-100 text-forest-900'
                  : 'text-ink-muted hover:bg-forest-100/60 hover:text-forest-900',
              ]}
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>
